{
  "root": true,
  "parser": "babel-eslint",
  "env": {
    "browser": true,
    "node": true,
    "jest": true,
    "es2021": true,
    "cypress/globals": false,
    "cypress": false
  },
  "extends": [
    "eslint:recommended",
    "plugin:jest/recommended"     // optional, adds Jest-specific rules
  ],
  "plugins": ["jest"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
     "allowImportExportEverywhere": true
  },
  "types": ["node", "jest"],
  "globals": {
    "Mocks": "readonly"
  }
}
