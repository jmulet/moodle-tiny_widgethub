{{!
    @template tiny_widgethub/sandbox

    Logic of the sandbox executor.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * wwwroot: The root URL of the Moodle site
    * jsrev: The revision number of the JavaScript files
    * origin: The origin of the Moodle site

    Example context (json):
    {
        "wwwroot": "https://moodle.example.com",
        "origin": "https://moodle.example.com",
        "jsrev": "1234567890"
    }
}}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>WidgetHub Render Sandbox</title>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Security-Policy" content="
    default-src 'none';
    script-src 'self' {{{origin}}} 'unsafe-eval';
    frame-src blob:;
    worker-src 'self';
    style-src 'self';
    connect-src 'none';
    img-src 'none';
    font-src 'none';
    media-src 'none';
    object-src 'none';
    base-uri 'none';
    form-action 'none';
    ">
    <link rel="workersrc" id="urlworker_mustache" href="{{{wwwroot}}}/lib/editor/tiny/plugins/widgethub/assets.php/js/{{jsrev}}/mustache_worker">
    <link rel="workersrc" id="urlworker_liquid" href="{{{wwwroot}}}/lib/editor/tiny/plugins/widgethub/assets.php/js/{{jsrev}}/liquid_worker">
    <link rel="workersrc" id="urlworker_ejs" href="{{{wwwroot}}}/lib/editor/tiny/plugins/widgethub/assets.php/js/{{jsrev}}/ejs_worker">
    <link rel="workersrc" id="urlworker_eval" href="{{{wwwroot}}}/lib/editor/tiny/plugins/widgethub/assets.php/js/{{jsrev}}/eval_worker">
    <script src="{{{wwwroot}}}/lib/editor/tiny/plugins/widgethub/assets.php/js/{{jsrev}}/render_sandbox"></script>
</head>
 <body>
</body>
</html>
