{{!
    @template tiny_widgethub/preview_modal

    Modal to configure existing widgets in the editor.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * content: The content to preview.

    Example context (json):
    {
        "content": "<p>Preview content</p>"
    }
 
}}
{{< core/modal }}
    {{$title}}
        {{#str}} preview, tiny_widgethub {{/str}}
    {{/title}}
    {{$body}} 
    <div id="tiny_widgethub_preview_action">
        {{{content}}}
    </div> 
    {{/body}}
    {{$footer}}
        <button class="tiny_widgethub-btn tiny_widgethub-btn-primary">{{#str}} accept, tiny_widgethub {{/str}}</button>
    {{/footer}}
{{/ core/modal }}